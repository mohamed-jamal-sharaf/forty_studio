// ==================== FULLSCREEN ====================
function toggleFullscreen(frm) {
    const wrapper = frm.fields_dict.editor_html.$wrapper;
    const container = wrapper.find('.monaco-wrapper');
    const btn = wrapper.find('.btn-fullscreen');

    if (!isFullscreen) {
        container.addClass('fullscreen');
        btn.html('<i class="fa fa-compress"></i> <span class="btn-label">Exit</span>');
        isFullscreen = true;
        $(document).on('keydown.fullscreen', (e) => { if (e.key === 'Escape') toggleFullscreen(frm); });
    } else {
        container.removeClass('fullscreen');
        btn.html('<i class="fa fa-expand"></i> <span class="btn-label">Fullscreen</span>');
        isFullscreen = false;
        $(document).off('keydown.fullscreen');
    }

    if (editor) setTimeout(() => editor.layout(), 100);
}

// ==================== UPDATE STATUS ====================
function updateSaveStatus(frm, isDirty) {
    const wrapper = frm.fields_dict.editor_html.$wrapper;
    const status = wrapper.find('.save-status');

    if (isDirty) {
        status.removeClass('saved').addClass('unsaved').html('<i class="fa fa-circle"></i> Unsaved');
    } else {
        status.removeClass('unsaved').addClass('saved').html('<i class="fa fa-check-circle"></i> Saved');
    }
}

// ==================== SAVE FILE ====================
async function saveFile(frm) {
    if (!editor || !frm.doc.app_name || !frm.doc.file_path) {
        showAlert('Missing app name or file path', 'warning');
        return;
    }

    const content = editor.getValue();

    try {
        const password = await showPasswordDialog({ action: 'save' });

        const response = await frappe.call({
            method: `${API_PATH}.write_file_content_with_backup`,
            args: { app_name: frm.doc.app_name, file_path: frm.doc.file_path, content: content, password: password }
        });

        if (response.message && response.message.success) {
            editorState.lastSavedContent = content;
            editorState.isDirty = false;
            updateSaveStatus(frm, false);
            showAlert(response.message.message, 'success');
        }
    } catch (error) {
        if (error !== 'cancelled') console.error("[ERROR] Save failed:", error);
    }
}

// ==================== COMPLETIONS ====================
function setupCompletions() {
    try {
        monaco.languages.registerCompletionItemProvider('javascript', {
            provideCompletionItems: (model, position) => {
                const word = model.getWordUntilPosition(position);
                const range = { startLineNumber: position.lineNumber, endLineNumber: position.lineNumber, startColumn: word.startColumn, endColumn: word.endColumn };
                return {
                    suggestions: [
                        { label: 'frappe.call', kind: monaco.languages.CompletionItemKind.Function, insertText: 'frappe.call({\n\tmethod: "${1:method}",\n\targs: { ${2} },\n\tcallback: function(r) {\n\t\t${3}\n\t}\n});', insertTextRules: monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet, range: range },
                        { label: 'frappe.msgprint', kind: monaco.languages.CompletionItemKind.Function, insertText: 'frappe.msgprint(__("${1:message}"));', insertTextRules: monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet, range: range },
                        { label: 'frappe.show_alert', kind: monaco.languages.CompletionItemKind.Function, insertText: 'frappe.show_alert({ message: __("${1}"), indicator: "${2|green,red,orange,blue|}" }, ${3:5});', insertTextRules: monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet, range: range },
                        { label: 'frm.set_value', kind: monaco.languages.CompletionItemKind.Function, insertText: 'frm.set_value("${1:fieldname}", ${2:value});', insertTextRules: monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet, range: range },
                        { label: 'frappe.ui.form.on', kind: monaco.languages.CompletionItemKind.Snippet, insertText: 'frappe.ui.form.on("${1:DocType}", {\n\trefresh: function(frm) {\n\t\t${2}\n\t}\n});', insertTextRules: monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet, range: range }
                    ]
                };
            }
        });

        monaco.languages.registerCompletionItemProvider('python', {
            provideCompletionItems: (model, position) => {
                const word = model.getWordUntilPosition(position);
                const range = { startLineNumber: position.lineNumber, endLineNumber: position.lineNumber, startColumn: word.startColumn, endColumn: word.endColumn };
                return {
                    suggestions: [
                        { label: '@frappe.whitelist()', kind: monaco.languages.CompletionItemKind.Snippet, insertText: '@frappe.whitelist()\ndef ${1:function_name}(${2}):\n\t${3:pass}', insertTextRules: monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet, range: range },
                        { label: 'frappe.get_doc', kind: monaco.languages.CompletionItemKind.Function, insertText: 'frappe.get_doc("${1:DocType}", "${2:name}")', insertTextRules: monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet, range: range },
                        { label: 'frappe.get_all', kind: monaco.languages.CompletionItemKind.Function, insertText: 'frappe.get_all("${1:DocType}", filters={${2}}, fields=["${3:name}"])', insertTextRules: monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet, range: range },
                        { label: 'frappe.throw', kind: monaco.languages.CompletionItemKind.Function, insertText: 'frappe.throw(_("${1:message}"))', insertTextRules: monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet, range: range }
                    ]
                };
            }
        });
    } catch (e) {
        console.error('Error setting up completions:', e);
    }
}

