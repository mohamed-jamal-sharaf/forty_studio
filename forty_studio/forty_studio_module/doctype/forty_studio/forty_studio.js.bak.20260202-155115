// ==================== INITIALIZE EDITOR ====================
function initEditor(frm) {
    const wrapper = frm.fields_dict.editor_html.$wrapper;
    const container = wrapper.find('.editor-container')[0];

    if (!container) {
        setTimeout(() => initEditor(frm), 500);
        return;
    }

    if (!window.monaco) return;

    if (editor) {
        try { editor.dispose(); editor = null; } catch (e) {}
    }

    const language = getFileLanguage(frm.doc.file_path);

    try {
        editor = monaco.editor.create(container, getEditorOptions(frm.doc.my_code, language));

        initializeUI(frm);
        setupEditorHandlers(frm);
        setupEditorEvents(frm);
        setupKeyboardShortcuts(frm);

        editor.onDidChangeModelContent(() => {
            const content = editor.getValue();
            frm.doc.my_code = content;

            if (content !== editorState.lastSavedContent) {
                editorState.isDirty = true;
                updateSaveStatus(frm, true);
            }
            updateEditorInfo(frm);
        });

        editorState.lastSavedContent = frm.doc.my_code || '';

        setTimeout(() => { if (editor) editor.layout(); }, 100);

        showAlert('Monaco Editor Ready!', 'success');

    } catch (e) {
        showAlert('Failed to create editor: ' + e.message, 'error');
    }
}

// ==================== INITIALIZE UI ====================
function initializeUI(frm) {
    const wrapper = frm.fields_dict.editor_html.$wrapper;

    wrapper.find('.select-theme').val(editorSettings.theme);
    wrapper.find('.input-fontsize').val(editorSettings.fontSize);
    wrapper.find('.label-fontsize').text(editorSettings.fontSize + 'px');
    wrapper.find('.select-tabsize').val(editorSettings.tabSize);

    wrapper.find('.toggle-wordwrap').prop('checked', editorSettings.wordWrap);
    wrapper.find('.toggle-minimap').prop('checked', editorSettings.minimap);
    wrapper.find('.toggle-linenumbers').prop('checked', editorSettings.lineNumbers);

    wrapper.find('.toggle-btn').each(function () {
        const input = $(this).find('input');
        $(this).toggleClass('active', input.is(':checked'));
    });

    const language = getFileLanguage(frm.doc.file_path);
    wrapper.find('.lang-name').text(language.charAt(0).toUpperCase() + language.slice(1));

    updateEditorInfo(frm);
}

// ==================== SETUP EDITOR HANDLERS ====================
function setupEditorHandlers(frm) {
    const wrapper = frm.fields_dict.editor_html.$wrapper;

    wrapper.find('.btn-save').off('click').on('click', () => saveFile(frm));
    wrapper.find('.btn-undo').off('click').on('click', () => editor && editor.trigger('keyboard', 'undo', null));
    wrapper.find('.btn-redo').off('click').on('click', () => editor && editor.trigger('keyboard', 'redo', null));
    wrapper.find('.btn-format').off('click').on('click', () => { if (editor) { editor.getAction('editor.action.formatDocument').run(); showAlert('Code Formatted', 'success'); } });
    wrapper.find('.btn-find').off('click').on('click', () => editor && editor.getAction('actions.find').run());
    wrapper.find('.btn-replace').off('click').on('click', () => editor && editor.getAction('editor.action.startFindReplaceAction').run());
    wrapper.find('.btn-comment').off('click').on('click', () => editor && editor.getAction('editor.action.commentLine').run());
    wrapper.find('.btn-fold-all').off('click').on('click', () => editor && editor.getAction('editor.foldAll').run());
    wrapper.find('.btn-unfold-all').off('click').on('click', () => editor && editor.getAction('editor.unfoldAll').run());
    wrapper.find('.btn-fullscreen').off('click').on('click', () => toggleFullscreen(frm));
    wrapper.find('.btn-settings').off('click').on('click', () => showSettingsDialog(frm));
    wrapper.find('.btn-keyboard').off('click').on('click', () => showKeyboardShortcuts());

    wrapper.find('.select-theme').off('change').on('change', function () {
        editorSettings.theme = $(this).val();
        saveSettings();
        if (editor) monaco.editor.setTheme(editorSettings.theme);
    });

    wrapper.find('.input-fontsize').off('input').on('input', function () {
        editorSettings.fontSize = parseInt($(this).val());
        saveSettings();
        wrapper.find('.label-fontsize').text(editorSettings.fontSize + 'px');
        if (editor) editor.updateOptions({ fontSize: editorSettings.fontSize });
    });

    wrapper.find('.select-tabsize').off('change').on('change', function () {
        editorSettings.tabSize = parseInt($(this).val());
        saveSettings();
        wrapper.find('.indent-info').text('Spaces: ' + editorSettings.tabSize);
        if (editor) editor.getModel().updateOptions({ tabSize: editorSettings.tabSize });
    });

    wrapper.find('.toggle-wordwrap').off('change').on('change', function () {
        editorSettings.wordWrap = $(this).is(':checked');
        saveSettings();
        $(this).closest('.toggle-btn').toggleClass('active', editorSettings.wordWrap);
        if (editor) editor.updateOptions({ wordWrap: editorSettings.wordWrap ? 'on' : 'off' });
    });

    wrapper.find('.toggle-minimap').off('change').on('change', function () {
        editorSettings.minimap = $(this).is(':checked');
        saveSettings();
        $(this).closest('.toggle-btn').toggleClass('active', editorSettings.minimap);
        if (editor) editor.updateOptions({ minimap: { enabled: editorSettings.minimap } });
    });

    wrapper.find('.toggle-linenumbers').off('change').on('change', function () {
        editorSettings.lineNumbers = $(this).is(':checked');
        saveSettings();
        $(this).closest('.toggle-btn').toggleClass('active', editorSettings.lineNumbers);
        if (editor) editor.updateOptions({ lineNumbers: editorSettings.lineNumbers ? 'on' : 'off' });
    });
}

// ==================== SETUP EDITOR EVENTS ====================
function setupEditorEvents(frm) {
    if (!editor) return;

    editor.onDidChangeCursorPosition((e) => {
        const wrapper = frm.fields_dict.editor_html.$wrapper;
        wrapper.find('.line-col').text(`Ln ${e.position.lineNumber}, Col ${e.position.column}`);
    });

    editor.onDidChangeCursorSelection((e) => {
        const wrapper = frm.fields_dict.editor_html.$wrapper;
        const selection = editor.getSelection();

        if (selection && !selection.isEmpty()) {
            const selectedText = editor.getModel().getValueInRange(selection);
            wrapper.find('.selection-info').show();
            wrapper.find('.selection-text').text(`${selectedText.length} chars, ${selectedText.split('\n').length} lines`);
        } else {
            wrapper.find('.selection-info').hide();
        }
    });
}

// ==================== UPDATE EDITOR INFO ====================
function updateEditorInfo(frm) {
    if (!editor) return;

    const wrapper = frm.fields_dict.editor_html.$wrapper;
    const model = editor.getModel();
    if (!model) return;

    const content = model.getValue();
    wrapper.find('.char-count').text(content.length.toLocaleString() + ' chars');
    wrapper.find('.line-count').text(model.getLineCount().toLocaleString() + ' lines');
}

// ==================== KEYBOARD SHORTCUTS ====================
function setupKeyboardShortcuts(frm) {
    if (!editor) return;

    editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.KeyS, () => saveFile(frm));
    editor.addCommand(monaco.KeyMod.Shift | monaco.KeyMod.Alt | monaco.KeyCode.KeyF, () => { editor.getAction('editor.action.formatDocument').run(); showAlert('Code Formatted', 'success'); });
    editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.Slash, () => editor.getAction('editor.action.commentLine').run());
    editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyMod.Shift | monaco.KeyCode.KeyD, () => editor.getAction('editor.action.copyLinesDownAction').run());
    editor.addCommand(monaco.KeyMod.Alt | monaco.KeyCode.UpArrow, () => editor.getAction('editor.action.moveLinesUpAction').run());
    editor.addCommand(monaco.KeyMod.Alt | monaco.KeyCode.DownArrow, () => editor.getAction('editor.action.moveLinesDownAction').run());
    editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyMod.Shift | monaco.KeyCode.KeyK, () => editor.getAction('editor.action.deleteLines').run());
    editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.KeyG, () => editor.getAction('editor.action.gotoLine').run());
    editor.addCommand(monaco.KeyCode.F11, () => toggleFullscreen(frm));
}

