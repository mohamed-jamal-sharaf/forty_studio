let APPS_OPTIONS = '';

function loadAppsOptions() {
    frappe.call({
        method: `${API_PATH}.get_installed_apps`,
        async: false,
        callback: function(r) {
            if (r.message) {
                APPS_OPTIONS = r.message;
            }
        }
    });
}

function setAppFieldOptions(frm) {
    if (!APPS_OPTIONS) return;
    
    // Set options on the app_name field
    frm.set_df_property('app_name', 'options', APPS_OPTIONS);
    frm.refresh_field('app_name');
}

