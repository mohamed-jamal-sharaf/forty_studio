async function showBackupsDialog(frm) {
    if (!frm.doc.file_path) { showAlert('Please select a file first', 'warning'); return; }

    try {
        const res = await frappe.call({
            method: `${API_PATH}.list_file_backups`,
            args: { app_name: frm.doc.app_name, file_path: frm.doc.file_path }
        });

        const backups = res.message || [];
        const fileName = frm.doc.file_path.split('/').pop();

        let backupsHTML = backups.length === 0
            ? `<div style="text-align: center; padding: 40px;"><div style="font-size: 48px;">📁</div><div>${__('No backups found')}</div></div>`
            : `<table class="table table-bordered"><thead><tr><th>${__('Timestamp')}</th><th>${__('Size')}</th><th>${__('Actions')}</th></tr></thead><tbody>
                ${backups.map(b => `<tr><td>${b.timestamp}</td><td>${b.size_formatted}</td><td>
                    <button class="btn btn-xs btn-default btn-view-backup" data-filename="${b.filename}">👁️ ${__('View')}</button>
                    <button class="btn btn-xs btn-primary btn-restore-backup" data-filename="${b.filename}" style="background: ${COLORS.primary};">↩️ ${__('Restore')}</button>
                </td></tr>`).join('')}
            </tbody></table>`;

        const dialog = new frappe.ui.Dialog({
            title: __('Backups: ') + fileName,
            size: 'large',
            fields: [{ fieldtype: 'HTML', fieldname: 'backups_list', options: backupsHTML }],
            primary_action_label: __('Close'),
            primary_action: () => dialog.hide()
        });

        dialog.show();

        dialog.$wrapper.find('.btn-view-backup').on('click', async function () {
            const content = await frappe.call({
                method: `${API_PATH}.read_backup_content`,
                args: { app_name: frm.doc.app_name, file_path: frm.doc.file_path, backup_filename: $(this).data('filename') }
            });
            const viewDialog = new frappe.ui.Dialog({
                title: __('Backup: ') + $(this).data('filename'),
                size: 'extra-large',
                fields: [{ fieldtype: 'Code', fieldname: 'content', options: getFileLanguage(frm.doc.file_path), default: content.message, read_only: 1 }],
                primary_action_label: __('Close'),
                primary_action: () => viewDialog.hide()
            });
            viewDialog.show();
        });

        dialog.$wrapper.find('.btn-restore-backup').on('click', async function () {
            try {
                const password = await showPasswordDialog({ action: 'save' });
                const res = await frappe.call({
                    method: `${API_PATH}.restore_backup`,
                    args: { app_name: frm.doc.app_name, file_path: frm.doc.file_path, backup_filename: $(this).data('filename'), password: password }
                });
                if (res.message?.success) {
                    showAlert(res.message.message, 'success');
                    dialog.hide();
                    await loadFileContent(frm, frm.doc.file_path);
                }
            } catch (error) { if (error !== 'cancelled') console.error('[ERROR]', error); }
        });
    } catch (error) { console.error('[ERROR]', error); }
}

