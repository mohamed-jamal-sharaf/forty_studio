        // Set app_name field options on meta
        if (APPS_OPTIONS) {
            frappe.meta.get_docfield('Forty Studio', 'app_name').options = APPS_OPTIONS;
        }
    },

    onload: async function (frm) {
        console.log('Forty Studio: Form loading...');

        // Load user permissions first
        await loadUserPermissions();

        // Set app options on the field
        setAppFieldOptions(frm);
    },

    refresh: function (frm) {
        console.log('Forty Studio: Refresh');

        // Set app options
        setAppFieldOptions(frm);

        // Add custom buttons based on permissions
        addCustomButtons(frm);

        // Create editor HTML
        if (frm.fields_dict.editor_html) {
            frm.fields_dict.editor_html.$wrapper.html(createEditorHTML());
        }

        if (frm.doc.app_name) {
            loadFilesList(frm);
        }

        if (frm.doc.my_code) {
            if (!isMonacoLoaded) {
                loadMonaco(() => setTimeout(() => initEditor(frm), 300));
            } else if (!editor) {
                setTimeout(() => initEditor(frm), 200);
            }
        }
    },

    app_name: function (frm) {
        frm.set_value('target_path', '');
        frm.set_value('file_path', '');
        frm.set_value('my_code', '');
        if (editor) editor.setValue('');
        loadFilesList(frm);
    },

    target_path: function (frm) {
        loadFilesList(frm);
    },

    file_path: function (frm) {
        if (frm.doc.file_path && isMonacoLoaded && editor) {
            const language = getFileLanguage(frm.doc.file_path);
            const model = editor.getModel();
            if (model) {
                monaco.editor.setModelLanguage(model, language);
                frm.fields_dict.editor_html.$wrapper.find('.lang-name').text(language.charAt(0).toUpperCase() + language.slice(1));
            }
        }
        addCustomButtons(frm);
    }
});

